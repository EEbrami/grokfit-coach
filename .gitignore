# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment Variables & Secrets
.env
.env.local
.env.*
!.env.example
secrets.json
credentials.json

# Local Data, Databases & Vector Stores (For Local RAG & LLMs)
*.db
*.sqlite
*.sqlite3
chroma_db/
.chromadb/
faiss_index/
lancedb/

# data/ : ignore generated indexes/artifacts but KEEP committed seed data for RAG.
# Use data/* (not data/) so children can be re-included; a bare data/ excludes the
# directory itself and makes negations impossible.
data/*
!data/seeds/
.artifacts/
var/
indexes/
data/indexes/
data/nutrition/
*.faiss
*.pkl  # often used by FAISS + docstore sidecars

# Local Model Weights / Large Binaries
*.gguf
*.bin
*.onnx

# Jupyter Notebooks (For prototyping/evaluation)
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# Tool caches & Testing
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
ehthumbs.db
*.swp
*.swo
